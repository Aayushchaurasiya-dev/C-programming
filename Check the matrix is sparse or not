 #include<stdio.h>
 int main(){
     int r,c;
     printf("enter the number of rows : ");
     scanf("%d",&r);
     printf("enter the number of column : ");
     scanf("%d",&c);
    
     int mat[r][c],i,j,counter =0;
     printf("enter matrix element : ");
     for(i=0;i<r;i++){
         for(j=0;j<c;j++){
         scanf("%d",&mat[i][j]);
         if (mat[i][j]==0 )
          counter++;
     }
     }
     printf("Matrix is :-\n");
     for(i=0;i<r;i++){
         for(j=0;j<c;j++){
         printf("%d\t",mat[i][j]);
     }
     printf("\n");
     }
     if (counter>r*c/2)
     printf("matrix is sparse");
     else printf("matrix is not sparse");
 }
 
