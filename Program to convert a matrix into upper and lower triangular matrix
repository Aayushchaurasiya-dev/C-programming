#include <stdio.h>

int main() {
 int r;
 printf("enter number of rows and column : ");
 scanf("%d",&r);
 int a[r][r],l[r][r],u[r][r],i,j;
 printf("enter matrix element : \n");
 for(i=0;i<r;i++)
 {
for(j=0;j<r;j++)
{
    scanf("%d",&a[i][j]);
}
 }
 printf("matrix is :\n");
 for(i=0;i<r;i++)
 {
for(j=0;j<r;j++)
{
    printf("%d\t",a[i][j]);
}
printf("\n");
 }
 printf("lower triangular matrix ;\n");
 for(i=0;i<r;i++)
 {
for(j=0;j<r;j++)
{
if(j>i){
    l[i][j] = 0;
}
else l[i][j]=a[i][j];
}
 }
 for(i=0;i<r;i++)
 {
for(j=0;j<r;j++)
{
    printf("%d\t",l[i][j]);
}
printf("\n");
 }
 
 printf("lower triangular matrix ;\n");
 for(i=0;i<r;i++)
 {
for(j=0;j<r;j++)
{
if(j<i){
    u[i][j] = 0;
}
else u[i][j]=a[i][j];
}
 }
 for(i=0;i<r;i++)
 {
for(j=0;j<r;j++)
{
    printf("%d\t",u[i][j]);
}
printf("\n");
 }
 
}
