 #include<stdio.h>
 int main(){
     int r;
     printf("enter the number of rows and column : ");
     scanf("%d",&r);
         
     int mat[r][r],i,j;
     printf("enter matrix element : ");
     for(i=0;i<r;i++){
         for(j=0;j<r;j++){
          scanf("%d",&mat[i][j]);
           if ((i-j)>1||(j-i)>1){
               mat[i][j]=0;
           }
           
     }
     }
     printf("tridiagonal matrix is :-\n");
     for(i=0;i<r;i++){
         for(j=0;j<r;j++){
         printf("%d\t",mat[i][j]);
     }
     printf("\n");
     }
     
 }
 
